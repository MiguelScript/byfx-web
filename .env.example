# URL base del sitio web (necesaria para SEO, sitemap y metadata)
# En producción: https://byfx.pro
# En desarrollo: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://byfx.pro

# Google Analytics 4 Measurement ID
# Obtén tu ID en: https://analytics.google.com/
# Formato: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Places API — reseñas de Google Maps
# Obtén tu API key en: https://console.cloud.google.com/
# Habilita: "Places API"
GOOGLE_PLACES_API_KEY=your_api_key_here

# Place ID de tu negocio en Google Maps
# Encuéntralo en: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=your_place_id_here
